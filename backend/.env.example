# ============================================================
# Enterprise Meet — Environment Variables Example
# Copy this to .env and fill in your values
# ============================================================

# -- Application --
APP_ENV=development
APP_NAME="Enterprise Meet API"
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# -- Security --
SECRET_KEY=your-super-secret-jwt-access-key-change-in-production-min-32-chars
REFRESH_SECRET_KEY=your-super-secret-jwt-refresh-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10

# -- Database (PostgreSQL) --
DATABASE_URL=postgresql+asyncpg://meetadmin:meetpassword@localhost:5432/enterprisemeet
DATABASE_SYNC_URL=postgresql://meetadmin:meetpassword@localhost:5432/enterprisemeet
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# -- Redis --
REDIS_URL=redis://localhost:6380/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# -- Celery --
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# -- Email (SMTP) --
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@enterprisemeet.local
SMTP_FROM_NAME="Enterprise Meet"

# -- Object Storage (MinIO) --
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_SECURE=false
MINIO_BUCKET_FILES=meet-files
MINIO_BUCKET_RECORDINGS=meet-recordings
MINIO_BUCKET_AVATARS=meet-avatars

# -- CORS --
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:4173"]
CORS_ALLOW_CREDENTIALS=true

# -- Rate Limiting --
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_WS=10/second

# -- WebRTC / TURN --
TURN_SERVER_URL=turn:localhost:3478
TURN_SERVER_USERNAME=meetuser
TURN_SERVER_CREDENTIAL=meetpassword
STUN_SERVER_URL=stun:stun.l.google.com:19302

# -- Frontend URL (for email links) --
FRONTEND_URL=http://localhost:3000

# -- Pagination --
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# -- Admin --
FIRST_ADMIN_EMAIL=admin@enterprisemeet.local
FIRST_ADMIN_PASSWORD=Admin@123456
